{
    "name": "barbersaas",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "prisma generate && next build",
        "start": "next start",
        "lint": "eslint . --max-warnings=0",
        "typecheck": "prisma generate && tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "smoke:http": "node scripts/smoke-http.mjs",
        "smoke:e2e": "playwright test -c playwright.smoke.config.ts",
        "smoke:e2e:auth": "playwright test -c playwright.homolog.config.ts",
        "smoke:a11y": "playwright test -c playwright.smoke.config.ts e2e/smoke/accessibility-smoke.spec.ts",
        "health:monitor": "node scripts/health-alert.mjs",
        "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:migrate:status": "prisma migrate status",
        "db:seed": "node prisma/seed.js",
        "prisma:generate": "prisma generate",
        "perf:audit": "node scripts/perf-audit.mjs"
    },
    "dependencies": {
        "@prisma/adapter-mariadb": "^7.6.0",
        "@prisma/client": "^7.6.0",
        "@sentry/nextjs": "^10.47.0",
        "bcryptjs": "^3.0.3",
        "dotenv": "^17.3.1",
        "mariadb": "^3.5.2",
        "next": "^16.1.7",
        "nodemailer": "^8.0.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/forms": "^0.5.11",
        "@types/node": "^22.13.4",
        "@types/nodemailer": "^7.0.11",
        "@types/react": "^19.1.2",
        "@types/react-dom": "^19.1.2",
        "@vitest/coverage-v8": "^4.1.1",
        "autoprefixer": "^10.4.20",
        "chrome-launcher": "^1.2.1",
        "eslint": "^9.23.0",
        "eslint-config-next": "^16.1.7",
        "lighthouse": "^13.0.3",
        "postcss": "^8.5.3",
        "prisma": "^7.6.0",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.8.2",
        "vitest": "^4.0.3"
    }
}
